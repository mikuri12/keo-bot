# Discord Bot Token - get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Gemini API Key - get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA API Key - get from https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Channel IDs where the bot should respond (comma-separated)
# Leave empty to respond in all channels where mentioned
ALLOWED_CHANNELS=

# Optional: Admin role name for managing the bot
ADMIN_ROLE=Admin
